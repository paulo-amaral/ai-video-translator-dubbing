# Copy this file to .env and fill only the providers you want to use.
# The .env file is ignored by Git.

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional gender-specific voice IDs
ELEVENLABS_VOICE_ID_MALE=
ELEVENLABS_VOICE_ID_FEMALE=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.80
ELEVENLABS_STYLE=0.15

# OpenAI TTS
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_TTS_INSTRUCTIONS="Speak as a natural professional video dub. Use warm, human pacing, subtle emotion, clear articulation, and natural pauses."

# OpenAI natural translation
OPENAI_TRANSLATION_MODEL=gpt-5-mini

# Gemini translation and TTS
GEMINI_API_KEY=
GEMINI_TRANSLATION_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
GEMINI_TTS_VOICE_MALE=Puck
GEMINI_TTS_VOICE_FEMALE=Kore
GEMINI_TTS_STYLE_PROMPT="Read this as natural professional video dubbing. Use warm conversational pacing, subtle emotional nuance, clear articulation, and natural pauses."

# Audio mix tuning
BACKGROUND_AUDIO_VOLUME=0.28
DUB_VOICE_VOLUME=1.0
DUB_AMBIENCE_DECAY=0.045
